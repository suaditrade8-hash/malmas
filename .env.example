# ============================================================
# ملمس · مثال ملفّ المتغيّرات السرّية (.env)
# انسخ هذا الملف إلى .env واملأ القيم — لا ترفع .env إلى Git
# ============================================================

# مفتاح Flask لتشفير الجلسات (session)
# ولّد قيمة عشوائية طويلة: python -c "import secrets; print(secrets.token_hex(32))"
# ملاحظة: على Render يُولَّد تلقائياً (generateValue: true في render.yaml)
SECRET_KEY=ضع-قيمة-عشوائية-طويلة-هنا

# كلمة مرور لوحة الإدارة — تظهر في نافذة دخول المتصفّح عند فتح /admin
# اسم المستخدم: أيّ شيء (admin مثلاً) · كلمة المرور: هذه القيمة
ADMIN_PASSWORD=ضع-كلمة-مرور-قويّة-هنا

# منفذ التشغيل المحلّي (Render يضع PORT تلقائياً)
PORT=5000
