# ============================================================
# ملمس · مثال ملفّ المتغيّرات السرّية (.env)
# انسخ هذا الملف إلى .env واملأ القيم — لا ترفع .env إلى Git
# ============================================================

# مفتاح Flask لتشفير الجلسات (session)
# ولّد قيمة عشوائية طويلة: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ضع-قيمة-عشوائية-طويلة-هنا

# بيانات Google OAuth — من console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=ضع-معرّف-العميل-من-Google
GOOGLE_CLIENT_SECRET=ضع-السرّ-من-Google

# قائمة بريد المدراء (Admin) — مفصولة بفواصل بدون مسافات
# أيّ بريد ضمن هذه القائمة يحصل على دور admin تلقائياً عند أوّل تسجيل دخول
ADMIN_EMAILS=your@email.com,partner@email.com

# منفذ التشغيل المحلّي (Render يضع PORT تلقائياً)
PORT=5000
